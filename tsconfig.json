{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022"],
    "types": ["node"],
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "rootDir": ".",
    "outDir": "dist",
    "noEmit": true
  },
  "include": [
    "app/**/*.ts",
    "src/**/*.ts",
    "tsp-output/server/js/src/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "tsp-output/server/js/src/generated/http/openapi3.ts"
  ]
}
